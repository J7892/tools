<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Notes</title>
    
    <link href="quill.snow.css" rel="stylesheet">
    
    <style>
        :root {
            --bg-color: #f5f5f5;
            --sidebar-bg: white;
            --editor-bg: white;
            --text-color: #333;
            --secondary-text: #888;
            --border-color: #ddd;
            --item-hover: #f0f0f0;
            --toolbar-bg: #fff;
        }

        [data-theme="dark"] {
            --bg-color: #1a1a1a;
            --sidebar-bg: #2d2d2d;
            --editor-bg: #2d2d2d;
            --text-color: #e0e0e0;
            --secondary-text: #aaa;
            --border-color: #444;
            --item-hover: #3d3d3d;
            --toolbar-bg: #333;
        }

        * { box-sizing: border-box; }
        body { 
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; 
            margin: 0; background: var(--bg-color); color: var(--text-color);
            height: 100vh; overflow: hidden; display: flex; 
        }
        
        .sidebar { 
            width: 280px; min-width: 280px; background: var(--sidebar-bg); padding: 15px; border-right: 1px solid var(--border-color); 
            display: flex; flex-direction: column; transition: margin-left 0.3s ease, background 0.3s; 
            margin-left: -280px; height: 100vh; z-index: 2000;
        }
        .sidebar.open { margin-left: 0; }
        .search-container { margin-bottom: 10px; }
        #sidebar-search { 
            width: 100%; padding: 8px; border: 1px solid var(--border-color); border-radius: 4px; outline: none; font-size: 0.85em; 
            background: var(--editor-bg); color: var(--text-color);
        }
        .note-list { flex-grow: 1; overflow-y: auto; margin-top: 10px; }
        .note-item { 
            padding: 10px; border-bottom: 1px solid var(--border-color); cursor: pointer; 
            display: flex; justify-content: space-between; align-items: center; 
            border-radius: 4px; transition: background 0.2s;
        }
        .note-item:hover { background: var(--item-hover); }
        .note-item.active { background: var(--item-hover); border-left: 4px solid #007bff; }

        .editor-area { 
            flex-grow: 1; background: var(--editor-bg); height: 100vh; 
            display: flex; flex-direction: column; padding: 20px 40px 10px 60px; 
            position: relative; min-width: 0; align-items: center; transition: background 0.3s; 
        }
        
        .content-width-wrapper { width: 100%; max-width: 100%; display: flex; flex-direction: column; flex-grow: 1; min-height: 0; transition: max-width 0.3s ease; }
        .content-width-wrapper.narrow { max-width: 800px; }

        .editor-content-wrapper { flex-grow: 1; display: flex; flex-direction: column; min-height: 0; width: 100%; overflow: visible; margin-top: 10px;}
        
        .custom-toolbar-wrapper {
            display: flex; justify-content: space-between; align-items: center;
            background: var(--toolbar-bg); border: 1px solid var(--border-color);
            border-bottom: none; border-top-left-radius: 4px; border-top-right-radius: 4px;
            padding-right: 12px; width: 100%;
        }

        .ql-toolbar.ql-snow { 
            border: none !important; flex-grow: 1; padding: 8px 12px !important; 
            display: flex; align-items: center; flex-wrap: nowrap; overflow-x: auto; 
        }

        .ql-snow .ql-stroke { stroke: var(--text-color) !important; }
        .ql-snow .ql-fill { fill: var(--text-color) !important; }
        .ql-snow .ql-picker { color: var(--text-color) !important; }

        .native-new-btn {
            background-color: #007bff; color: white; border: none; border-radius: 4px;
            padding: 0 16px; font-weight: 600; font-size: 13px; cursor: pointer;
            height: 32px; white-space: nowrap; flex-shrink: 0; 
            display: flex; align-items: center; justify-content: center;
            transition: background-color 0.2s;
        }
        .native-new-btn:hover { background-color: #0056b3; }

        .toggle-sidebar { 
            background: #333; color: white; padding: 0 15px; cursor: pointer; 
            border-radius: 0 4px 4px 0; border: none; font-size: 1.2em; height: 50px; 
            display: flex; align-items: center; justify-content: center;
            position: absolute; left: 0; top: 20px; z-index: 1100;
        }

        .ql-container.ql-snow {
            border: 1px solid var(--border-color) !important;
            border-bottom-left-radius: 4px; border-bottom-right-radius: 4px;
        }

        .ql-editor { flex-grow: 1; overflow-y: auto; padding-bottom: 20px; line-height: 1.3; }
        
        /* Title Styling */
        .ql-editor > *:first-child {
            font-size: 1.5em !important; font-weight: bold !important;
            margin-bottom: 0.5em !important; line-height: 1.2 !important;
        }

        .ql-editor p { margin-bottom: 0.5em !important; } 
        .ql-editor p:last-child { margin-bottom: 0 !important; }

        #editor-container.zoom-small .ql-editor { font-size: 13px; }
        #editor-container.zoom-normal .ql-editor { font-size: 16px; }
        #editor-container.zoom-large .ql-editor { font-size: 20px; }
        #editor-container.zoom-huge .ql-editor { font-size: 28px; }

        .bottom-bar { 
            display: flex; justify-content: space-between; align-items: center; 
            padding: 8px 0; border-top: 1px solid var(--border-color); margin-top: 5px; 
            width: 100%; flex-shrink: 0; background: var(--editor-bg);
        }

        .modal-overlay {
            display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.5); z-index: 3000; justify-content: center; align-items: center;
        }
        .modal-overlay.active { display: flex; }
        .modal-content {
            background: var(--editor-bg); color: var(--text-color); padding: 25px;
            border-radius: 8px; border: 1px solid var(--border-color); text-align: center; max-width: 400px;
        }

        @media (max-width: 768px) {
            .editor-area { padding: 5px; } 
            .toggle-sidebar { position: static; height: 32px; width: 36px; padding: 0; margin-right: 4px; border-radius: 4px; }
            .native-new-btn .btn-text { display: none; }
            .native-new-btn { padding: 0; width: 32px; font-size: 18px; }
        }
    </style>
</head>
<body>

    <div id="sidebar" class="sidebar">
        <button class="btn-new-sidebar" onclick="createNewNote()">+ New Note</button>
        <div class="search-container">
            <input type="text" id="sidebar-search" placeholder="Search..." oninput="renderNoteList()">
        </div>
        <div id="note-list" class="note-list"></div>
        <div style="margin-top: auto; padding-top: 15px; border-top: 1px solid var(--border-color);">
            <button onclick="exportNotes()">Backup</button>
            <button onclick="document.getElementById('import-input').click()">Import</button>
            <input type="file" id="import-input" style="display:none" onchange="importNotes(event)">
        </div>
    </div>

    <div class="editor-area">
        <div id="width-wrapper" class="content-width-wrapper">
            <button class="toggle-sidebar" onclick="toggleSidebar()">☰</button>
            <div class="editor-content-wrapper">
                <div id="editor-container"></div>
            </div>
            <div class="bottom-bar">
                <span id="status">Saved</span>
                <span id="stats-display">0w | 0c</span>
                <button onclick="copyNote()">Copy</button>
            </div>
        </div>
    </div>

    <div id="backup-modal" class="modal-overlay">
        <div class="modal-content">
            <h3>Daily Backup</h3>
            <p>Ready for your daily backup? Click below to save your notes to your computer.</p>
            <div style="display:flex; gap:10px; justify-content:center; margin-top:20px;">
                <button onclick="dismissBackupPrompt()">Later</button>
                <button class="native-new-btn" onclick="executePromptedBackup()">Backup Now</button>
            </div>
        </div>
    </div>

<script src="quill.js"></script>
<script>
    const APP_VERSION = 1.1;
    let currentNoteId = null;
    let saveTimeout = null;
    let isDirty = false;

    var quill = new Quill('#editor-container', {
        modules: {
            toolbar: {
                container: [[{ 'size': ['small', false, 'large', 'huge'] }], ['link'], ['clean']],
                handlers: { 'size': (val) => applyZoom(val) }
            }
        },
        theme: 'snow'
    });

    const toolbarEl = document.querySelector('.ql-toolbar');
    const customWrapper = document.createElement('div');
    customWrapper.className = 'custom-toolbar-wrapper';
    toolbarEl.parentNode.insertBefore(customWrapper, toolbarEl);
    customWrapper.appendChild(document.querySelector('.toggle-sidebar'));
    customWrapper.appendChild(toolbarEl);

    const nativeBtn = document.createElement('button');
    nativeBtn.className = 'native-new-btn';
    nativeBtn.innerHTML = '<span class="plus-sign">+</span><span class="btn-text">&nbsp;NEW NOTE</span>';
    nativeBtn.onclick = createNewNote;
    customWrapper.appendChild(nativeBtn);

    function createNewNote() {
        currentNoteId = Date.now();
        const today = new Date();
        const mm = String(today.getMonth() + 1).padStart(2, '0');
        const dd = String(today.getDate()).padStart(2, '0');
        const dateText = `${mm}-${dd} - `;
        quill.setText(`${dateText}\n\n`, 'user');
        quill.setSelection(dateText.length, 0);
        quill.focus();
    }

    function checkBackupPrompt() {
        if (sessionStorage.getItem('backup-prompt-dismissed')) return;
        const lastBackup = localStorage.getItem('last-backup-date');
        const now = new Date().getTime();
        const oneDay = 24 * 60 * 60 * 1000;
        if (!lastBackup || (now - new Date(lastBackup).getTime() > oneDay)) {
            document.getElementById('backup-modal').classList.add('active');
        }
    }

    function exportNotes() {
        const raw = localStorage.getItem('my-github-notes');
        const blob = new Blob([raw], { type: 'application/json' });
        const a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = `notes_backup_${new Date().toISOString().split('T')[0]}.json`;
        a.click();
        localStorage.setItem('last-backup-date', new Date().toISOString());
    }

    function executePromptedBackup() { exportNotes(); dismissBackupPrompt(); }
    function dismissBackupPrompt() { 
        sessionStorage.setItem('backup-prompt-dismissed', 'true');
        document.getElementById('backup-modal').classList.remove('active'); 
    }

    // [Standard auto-save and logic functions continue as before...]
    window.onload = () => { setTimeout(checkBackupPrompt, 1500); };
</script>
</body>
</html>
