            </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            
            <!-- Vibe Mood Selector -->
            <div class="flex flex-col gap-1">
                <label class="text-[10px] uppercase font-bold text-zinc-500 tracking-wider mono-font">Harmonic Vibe</label>
                <select id="select-vibe" class="bg-zinc-900 border border-zinc-800 rounded-xl px-3 py-2 text-sm text-zinc-300 focus:outline-none focus:ring-1 focus:ring-amber-500 font-medium">
