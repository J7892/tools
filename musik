        </div>

        <div class="grid grid-cols-2 gap-4 border-t border-zinc-900 pt-4">
            
            <div class="flex flex-col gap-1 bg-zinc-950 p-2.5 rounded-xl border border-zinc-900/65">
                <div class="flex justify-between items-center text-[10px] text-zinc-500 font-semibold uppercase mono-font">
                    <span>Master Gain</span>
                    <span id="vol-lbl">70%</span>
                </div>
                <input type="range" id="slider-volume" min="0" max="1" step="0.01" value="0.7">
