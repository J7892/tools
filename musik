                </div>
            </div>

            <!-- Track Display Details -->
            <div class="flex-grow w-full text-center md:text-left flex flex-col gap-1.5 min-w-0">
                <div id="track-title" class="text-lg font-bold text-amber-400 truncate tracking-wide leading-snug">Station Off-Air</div>
                <div class="flex flex-wrap justify-center md:justify-start gap-x-3 gap-y-1 text-xs mono-font text-zinc-400">
                    <span id="bpm-display">BPM: --</span>
                    <span>•</span>
                    <span id="scale-display" class="truncate max-w-[150px]">VIBE: --</span>
                </div>
                
                <!-- Simulated Cassette Playback Playlist Progress Slider -->
                <div class="mt-2 w-full">
                    <div class="flex justify-between items-center text-[10px] text-zinc-500 uppercase tracking-wider mb-1 font-semibold mono-font">
                        <span>Track Progress</span>
