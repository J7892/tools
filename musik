<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cozy Procedural Lo-Fi Radio</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
    
    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #09080d;
            background-image: radial-gradient(circle at center, #161122 0%, #060508 100%);
        }
        .mono-font {
            font-family: 'JetBrains Mono', monospace;
        }
        @keyframes spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
        .vinyl-spin {
            animation: spin var(--spin-duration, 4s) linear infinite;
        }
    </style>
</head>
<body class="min-h-screen text-amber-50/90 flex flex-col justify-center items-center p-4 select-none">

    <!-- Rigidly dimensioned frame structure preventing all layout alterations -->
    <div class="w-[370px] h-[640px] bg-zinc-950 border border-zinc-800 rounded-[28px] p-5 shadow-2xl flex flex-col justify-between relative overflow-hidden box-border">
        
        <!-- Header Strip -->
        <div class="flex justify-between items-center border-b border-zinc-900 pb-3 h-6">
            <div class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
                <span class="text-[10px] uppercase font-bold text-zinc-500 tracking-wider mono-font">Procedural Audio Station</span>
            </div>
            <div class="text-[10px] uppercase tracking-widest text-teal-400 font-bold mono-font tabular-nums" id="deck-status">
                OFFLINE
            </div>
        </div>

        <!-- Tape / Deck Bay -->
        <div class="h-28 bg-zinc-900/40 rounded-2xl border border-zinc-900 p-3 flex items-center gap-4 box-border">
            <!-- Vinyl Disk Layer -->
            <div class="w-20 h-20 shrink-0 relative flex-none bg-black rounded-full shadow-inner flex items-center justify-center border border-zinc-800">
                <div id="vinyl-disc" class="w-full h-full rounded-full bg-gradient-to-tr from-zinc-900 via-zinc-950 to-zinc-800 flex items-center justify-center relative">
                    <div class="absolute inset-1.5 border border-zinc-900/50 rounded-full"></div>
                    <div class="absolute inset-3.5 border border-zinc-900/40 rounded-full"></div>
                    <div class="absolute inset-5 border border-zinc-900/20 rounded-full"></div>
                    <div class="w-7 h-7 rounded-full bg-amber-500/90 flex items-center justify-center border border-black shadow">
                        <div class="w-1.5 h-1.5 rounded-full bg-zinc-950"></div>
                    </div>
                </div>
            </div>

            <!-- Meta text displays locked with monospacing and strict bounds -->
            <div class="flex-grow min-w-0 flex flex-col justify-center h-full">
                <div id="track-title" class="text-sm font-bold text-amber-400 truncate tracking-wide mb-1">Station Stopped</div>
                <div class="flex gap-2 text-[10px] mono-font text-zinc-500 font-bold uppercase tracking-wider mb-2">
                    <span id="bpm-display" class="tabular-nums">BPM: --</span>
                    <span>|</span>
                    <span id="scale-display" class="truncate max-w-[110px]">VIBE: --</span>
                </div>
                
                <!-- Playlist Progress Strip -->
                <div class="w-full">
                    <div class="flex justify-between items-center text-[9px] text-zinc-500 font-bold uppercase tracking-wider mb-1 mono-font">
                        <span>Buffer Progress</span>
                        <span id="time-left" class="tabular-nums">04:00</span>
                    </div>
                    <div class="w-full h-1 bg-zinc-950 rounded-full overflow-hidden">
                        <div id="track-progress-bar" class="w-0 h-full bg-gradient-to-r from-amber-500 to-teal-400 rounded-full transition-all duration-1000 ease-linear"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Parameters Selector Grid -->
        <div class="grid grid-cols-1 gap-3 box-border">
            <div class="flex flex-col gap-1">
                <label class="text-[9px] uppercase font-bold text-zinc-500 tracking-wider mono-font">Harmonic Vibe</label>
                <select id="select-vibe" class="bg-zinc-900 border border-zinc-800 rounded-xl px-3 py-2 text-xs text-zinc-300 focus:outline-none focus:ring-1 focus:ring-amber-500 font-medium w-full">
                    <option value="minor">Melancholic (Natural Minor)</option>
                    <option value="major">Warm & Cozy (Major)</option>
                    <option value="dorian">Hypnotic (Dorian Mode)</option>
                    <option value="phrygian">Mysterious (Phrygian Mode)</option>
                </select>
            </div>

            <div class="flex flex-col gap-1">
                <label class="text-[9px] uppercase font-bold text-zinc-500 tracking-wider mono-font">Drum Rhythm Style</label>
                <select id="select-beat" class="bg-zinc-900 border border-zinc-800 rounded-xl px-3 py-2 text-xs text-zinc-300 focus:outline-none focus:ring-1 focus:ring-amber-500 font-medium w-full">
                    <option value="boombap">Classic Boom Bap (MPC Swing)</option>
                    <option value="chillhop">Slow Organic Chill Hop (Lazy Layout)</option>
                    <option value="garage">Garage Swing Grooves (Uptempo 2-Step)</option>
                    <option value="beatless">Atmospheric Beatless Ambient</option>
                </select>
            </div>

            <div class="flex flex-col gap-1">
                <label class="text-[9px] uppercase font-bold text-zinc-500 tracking-wider mono-font">Synth Lead Voice</label>
                <select id="select-synth" class="bg-zinc-900 border border-zinc-800 rounded-xl px-3 py-2 text-xs text-zinc-300 focus:outline-none focus:ring-1 focus:ring-amber-500 font-medium w-full">
                    <option value="rhodes">Warm Electric Rhodes</option>
                    <option value="sines">Floating Dream Sines</option>
                    <option value="bells">Filtered Square Bells</option>
                    <option value="plucks">Plucky Triangles</option>
                </select>
            </div>
        </div>

        <!-- Deck Core Interfaces -->
        <div class="grid grid-cols-3 gap-2.5 h-11 shrink-0">
            <button id="skip-btn" class="bg-zinc-900 hover:bg-zinc-800 active:scale-95 text-zinc-400 transition-all px-2 rounded-xl font-bold uppercase tracking-wider text-[10px] border border-zinc-800 flex justify-center items-center gap-1.5">
                <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24"><path d="M6 18l8.5-6L6 6v12zM16 6v12h2V6h-2z"/></svg>
                Skip
            </button>
            <button id="play-btn" class="col-span-2 bg-gradient-to-r from-amber-500 to-orange-500 text-black active:scale-95 transition-all rounded-xl font-extrabold uppercase tracking-widest text-xs flex justify-center items-center gap-1.5 shadow-lg">
                <span id="play-btn-text">Tune In</span>
            </button>
        </div>

        <!-- Analog Audio Strip Board -->
        <div class="grid grid-cols-2 gap-x-4 gap-y-2 bg-zinc-900/20 p-2.5 rounded-xl border border-zinc-900 box-border text-[9px] text-zinc-500 font-bold uppercase tracking-wider mono-font">
            <div class="flex flex-col gap-1">
                <div class="flex justify-between tabular-nums"><span>Volume</span><span id="vol-lbl">70%</span></div>
                <input type="range" id="slider-volume" min="0" max="1" step="0.01" value="0.7" class="w-full accent-orange-500 h-1 bg-zinc-800 rounded-lg appearance-none outline-none">
            </div>
            <div class="flex flex-col gap-1">
                <div class="flex justify-between tabular-nums"><span>Rain FX</span><span id="rain-lbl">40%</span></div>
                <input type="range" id="slider-rain" min="0" max="0.15" step="0.005" value="0.06" class="w-full accent-orange-500 h-1 bg-zinc-800 rounded-lg appearance-none outline-none">
            </div>
            <div class="flex flex-col gap-1">
                <div class="flex justify-between tabular-nums"><span>Crackle</span><span id="crackle-lbl">25%</span></div>
                <input type="range" id="slider-crackle" min="0" max="0.04" step="0.002" value="0.01" class="w-full accent-orange-500 h-1 bg-zinc-800 rounded-lg appearance-none outline-none">
            </div>
            <div class="flex flex-col gap-1">
                <div class="flex justify-between tabular-nums"><span>Filter</span><span id="cutoff-lbl">1.8k</span></div>
                <input type="range" id="slider-cutoff" min="500" max="4000" step="50" value="1800" class="w-full accent-orange-500 h-1 bg-zinc-800 rounded-lg appearance-none outline-none">
            </div>
        </div>

        <!-- Isolated HTML5 Canvas Frame (Completely breaks out from Document Layout Flow) -->
        <div class="w-full h-11 bg-black/40 border border-zinc-900 rounded-xl overflow-hidden box-border">
            <canvas id="canvas-visualizer" class="w-full h-full block"></canvas>
        </div>

    </div>

    <script>
        let audioCtx;
        let masterGain;
        let lofiFilter;
        
        let crackleSource, crackleGain;
        let rainSource, rainGain;
        let delayNode, delayFeedback;
        let noiseBuffer;

        let isPlaying = false;
        let isTransitioning = false;
        let transitionTimeout = null;

        // Sequencing variables
        let currentStep = 0;
        let measureCount = 0;
        let nextNoteTime = 0.0;
        let bpm = 74;
        const lookahead = 25.0;
        const scheduleAheadTime = 0.15;
        let timerID;

        let songTimeElapsed = 0;
        let autoSkipDuration = 240; // 4 minutes
        let timerIntervalID;

        // Melodic loop matrices
        let activeMotif = [];
        let currentModeKey = "minor";
        let currentBeatStyle = "boombap";
        let currentSynthVoice = "rhodes";
        let activeProgression = null;
        let activeChordIndex = 0;

        // Visualizer engine setup
        const canvas = document.getElementById('canvas-visualizer');
        const ctx = canvas.getContext('2d');
        let visBarsArray = new Array(16).fill(0); // Cache heights inside JS memory space
        let animationFrameId;

        // DOM elements cache
        const selectVibe = document.getElementById('select-vibe');
        const selectBeat = document.getElementById('select-beat');
        const selectSynth = document.getElementById('select-synth');
        const playBtn = document.getElementById('play-btn');
        const playBtnText = document.getElementById('play-btn-text');
        const skipBtn = document.getElementById('skip-btn');
        const trackTitleDisplay = document.getElementById('track-title');
        const deckStatus = document.getElementById('deck-status');
        const bpmDisplay = document.getElementById('bpm-display');
        const scaleDisplay = document.getElementById('scale-display');
        const progressBar = document.getElementById('track-progress-bar');
        const timeLeftDisplay = document.getElementById('time-left');
        const vinylDisc = document.getElementById('vinyl-disc');

        const sliderVolume = document.getElementById('slider-volume');
        const sliderRain = document.getElementById('slider-rain');
        const sliderCrackle = document.getElementById('slider-crackle');
        const sliderCutoff = document.getElementById('slider-cutoff');

        // Dynamic Frequency Banks
        const modes = {
            minor: { name: "Minor", scale: [65.41, 73.42, 77.78, 87.31, 98.00, 103.83, 116.54, 130.81, 146.83, 155.56, 174.61, 196.00, 207.65, 233.08, 261.63, 293.66, 311.13, 349.23, 392.00, 415.30, 466.16, 523.25, 587.33, 622.25, 698.46, 783.99, 830.61, 932.33], progressions: [{ chords: [[7, 10, 14, 17], [10, 13, 17, 21], [11, 14, 18, 22], [9, 12, 16, 19]] }] },
            major: { name: "Major", scale: [65.41, 73.42, 82.41, 87.31, 98.00, 110.00, 123.47, 130.81, 146.83, 164.81, 174.61, 196.00, 220.00, 246.94, 261.63, 293.66, 329.63, 349.23, 392.00, 440.00, 493.88, 523.25, 587.33, 659.25, 698.46, 783.99, 880.00, 987.77], progressions: [{ chords: [[7, 11, 14, 18], [10, 14, 17, 21], [8, 12, 15, 19], [9, 13, 16, 20]] }] },
            dorian: { name: "Dorian", scale: [65.41, 73.42, 77.78, 87.31, 98.00, 110.00, 116.54, 130.81, 146.83, 155.56, 174.61, 196.00, 220.00, 233.08, 261.63, 293.66, 311.13, 349.23, 392.00, 440.00, 466.16, 523.25, 587.33, 622.25, 698.46, 783.99, 880.00, 932.33], progressions: [{ chords: [[7, 10, 14, 19], [12, 16, 19, 23], [10, 13, 17, 21], [9, 12, 16, 19]] }] },
            phrygian: { name: "Phrygian", scale: [65.41, 69.30, 77.78, 87.31, 98.00, 103.83, 116.54, 130.81, 138.59, 155.56, 174.61, 196.00, 207.65, 233.08, 261.63, 277.18, 311.13, 349.23, 392.00, 415.30, 466.16, 523.25, 554.37, 622.25, 698.46, 783.99, 830.61, 932.33], progressions: [{ chords: [[7, 10, 14, 17], [8, 11, 14, 18], [10, 13, 17, 21], [7, 10, 14, 17]] }] }
        };

        const adjectives = ["Midnight", "Autumn", "Distant", "Cozy", "Dreamy", "Rainy", "Tokyo", "Silent", "Warm", "Urban"];
        const nouns = ["Coffee", "Skyline", "Transit", "Memory", "Raindrops", "Loft", "Nostalgia", "Window", "Cafe", "Station"];

        function makeTrackTitle() {
            return `🎧 ${adjectives[Math.floor(Math.random() * adjectives.length)]} ${nouns[Math.floor(Math.random() * nouns.length)]}`;
        }

        // Adjust resolution on canvas to map exactly to layout sizes
        function resizeCanvas() {
            canvas.width = canvas.clientWidth;
            canvas.height = canvas.clientHeight;
        }
        window.addEventListener('resize', resizeCanvas);
        resizeCanvas();

        function initAudioPipeline() {
            audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            
            masterGain = audioCtx.createGain();
            masterGain.gain.setValueAtTime(parseFloat(sliderVolume.value), audioCtx.currentTime);

            lofiFilter = audioCtx.createBiquadFilter();
            lofiFilter.type = 'lowpass';
            lofiFilter.frequency.setValueAtTime(parseFloat(sliderCutoff.value), audioCtx.currentTime);

            const bufferSize = audioCtx.sampleRate * 2;
            noiseBuffer = audioCtx.createBuffer(1, bufferSize, audioCtx.sampleRate);
            const channelData = noiseBuffer.getChannelData(0);
            for (let i = 0; i < bufferSize; i++) channelData[i] = Math.random() * 2 - 1;

            crackleSource = audioCtx.createBufferSource();
            crackleSource.buffer = noiseBuffer;
            crackleSource.loop = true;
            const crackleFilter = audioCtx.createBiquadFilter();
            crackleFilter.type = 'bandpass';
            crackleFilter.frequency.setValueAtTime(1600, audioCtx.currentTime);
            crackleFilter.Q.setValueAtTime(3.5, audioCtx.currentTime);
            crackleGain = audioCtx.createGain();
            crackleGain.gain.setValueAtTime(parseFloat(sliderCrackle.value), audioCtx.currentTime);
            crackleSource.connect(crackleFilter).connect(crackleGain).connect(masterGain);
            crackleSource.start();

            rainSource = audioCtx.createBufferSource();
            rainSource.buffer = noiseBuffer;
            rainSource.loop = true;
            const rfL = audioCtx.createBiquadFilter(); rfL.type = 'lowpass'; rfL.frequency.setValueAtTime(450, audioCtx.currentTime);
            const rfH = audioCtx.createBiquadFilter(); rfH.type = 'highpass'; rfH.frequency.setValueAtTime(140, audioCtx.currentTime);
            rainGain = audioCtx.createGain();
            rainGain.gain.setValueAtTime(parseFloat(sliderRain.value), audioCtx.currentTime);
            rainSource.connect(rfL).connect(rfH).connect(rainGain).connect(masterGain);
            rainSource.start();

            delayNode = audioCtx.createDelay(3.0);
            delayNode.delayTime.setValueAtTime((60.0 / bpm) * 0.75, audioCtx.currentTime);
            delayFeedback = audioCtx.createGain();
            delayFeedback.gain.setValueAtTime(0.35, audioCtx.currentTime);
            delayNode.connect(delayFeedback).connect(delayNode);
            delayNode.connect(lofiFilter);

            lofiFilter.connect(masterGain).connect(audioCtx.destination);
        }

        // --- AUDIO INSTRUMENT NETWORKS ---
        function synthKick(time) {
            if (isTransitioning) return;
            const osc = audioCtx.createOscillator(); const gain = audioCtx.createGain();
            osc.connect(gain).connect(lofiFilter);
            osc.frequency.setValueAtTime(130, time); osc.frequency.exponentialRampToValueAtTime(0.01, time + 0.3);
            gain.gain.setValueAtTime(1.0, time); gain.gain.exponentialRampToValueAtTime(0.001, time + 0.3);
            osc.start(time); osc.stop(time + 0.3);
            pokeBar(0, 0.95); pokeBar(1, 0.8);
        }

        function synthSnare(time, isRim = false) {
            if (isTransitioning) return;
            const osc = audioCtx.createOscillator(); const oGain = audioCtx.createGain();
            osc.type = 'triangle'; osc.connect(oGain).connect(lofiFilter);
            osc.frequency.setValueAtTime(isRim ? 400 : 175, time);
            oGain.gain.setValueAtTime(isRim ? 0.15 : 0.3, time);
            oGain.gain.exponentialRampToValueAtTime(0.001, time + 0.15);
            osc.start(time); osc.stop(time + 0.15);

            const noise = audioCtx.createBufferSource(); noise.buffer = noiseBuffer;
            const filter = audioCtx.createBiquadFilter(); filter.type = 'highpass'; filter.frequency.setValueAtTime(isRim ? 2000 : 1100, time);
            const nGain = audioCtx.createGain(); nGain.gain.setValueAtTime(isRim ? 0.08 : 0.25, time);
            nGain.gain.exponentialRampToValueAtTime(0.001, time + 0.15);
            noise.connect(filter).connect(nGain).connect(lofiFilter);
            noise.start(time); noise.stop(time + 0.15);
            pokeBar(4, 0.85); pokeBar(5, 0.75);
        }

        function synthHiHat(time, isOpen = false) {
            if (isTransitioning) return;
            const noise = audioCtx.createBufferSource(); noise.buffer = noiseBuffer;
            const filter = audioCtx.createBiquadFilter(); filter.type = 'bandpass'; filter.frequency.setValueAtTime(isOpen ? 6500 : 8500, time);
            const gain = audioCtx.createGain(); gain.gain.setValueAtTime(isOpen ? 0.1 : 0.05, time);
            gain.gain.exponentialRampToValueAtTime(0.001, time + (isOpen ? 0.25 : 0.04));
            noise.connect(filter).connect(gain).connect(lofiFilter);
            noise.start(time); noise.stop(time + (isOpen ? 0.25 : 0.04));
            pokeBar(isOpen ? 9 : 8, isOpen ? 0.6 : 0.35);
        }

        function synthChord(time, chordIndices) {
            if (isTransitioning) return;
            const tMode = modes[currentModeKey]; if (!tMode) return;
            chordIndices.forEach(index => {
                const freq = tMode.scale[index] || 261.63;
                for (let i = 0; i < 2; i++) {
                    const osc = audioCtx.createOscillator(); const gain = audioCtx.createGain();
                    osc.type = currentSynthVoice === 'bells' ? 'square' : (currentSynthVoice === 'plucks' ? 'triangle' : 'sine');
                    if (currentSynthVoice === 'rhodes' && i === 1) osc.type = 'triangle';
                    
                    osc.frequency.setValueAtTime(freq, time);
                    osc.detune.setValueAtTime((Math.random() - 0.5) * 12, time);
                    osc.connect(gain).connect(lofiFilter);

                    gain.gain.setValueAtTime(0, time);
                    if (currentSynthVoice === 'plucks') {
                        gain.gain.linearRampToValueAtTime(0.06, time + 0.02); gain.gain.exponentialRampToValueAtTime(0.001, time + 0.6);
                    } else if (currentSynthVoice === 'bells') {
                        gain.gain.linearRampToValueAtTime(0.05, time + 0.04); gain.gain.exponentialRampToValueAtTime(0.001, time + 1.1);
                    } else { // Rhodes / Sines
                        gain.gain.linearRampToValueAtTime(0.1, time + 0.25); gain.gain.setTargetAtTime(0, time + 1.8, 0.7);
                    }
                    osc.start(time); osc.stop(time + 3.5);
                }
            });
            pokeBar(2, 0.7); pokeBar(3, 0.65);
        }

        function synthBass(time, bIdx) {
            if (isTransitioning) return;
            const tMode = modes[currentModeKey]; if (!tMode) return;
            const osc = audioCtx.createOscillator(); const gain = audioCtx.createGain();
            osc.type = 'triangle'; osc.frequency.setValueAtTime(tMode.scale[bIdx - 7] || tMode.scale[0], time);
            osc.connect(gain).connect(lofiFilter);
            gain.gain.setValueAtTime(0, time); gain.gain.linearRampToValueAtTime(0.35, time + 0.1); gain.gain.exponentialRampToValueAtTime(0.001, time + 1.6);
            osc.start(time); osc.stop(time + 1.6);
        }

        function synthMelody(time, nIdx) {
            if (isTransitioning) return;
            const tMode = modes[currentModeKey]; if (!tMode) return;
            const osc = audioCtx.createOscillator(); const gain = audioCtx.createGain();
            osc.type = currentSynthVoice === 'bells' ? 'square' : (currentSynthVoice === 'plucks' ? 'triangle' : 'sine');
            osc.frequency.setValueAtTime(tMode.scale[nIdx] || 523.25, time);
            osc.connect(gain).connect(lofiFilter); gain.connect(delayNode);
            gain.gain.setValueAtTime(0, time); gain.gain.linearRampToValueAtTime(0.08, time + 0.05); gain.gain.exponentialRampToValueAtTime(0.001, time + 1.0);
            osc.start(time); osc.stop(time + 1.0);
            pokeBar(13, 0.7); pokeBar(14, 0.6);
        }

        function generateMelodicMotif() {
            const range = [14, 16, 17, 18, 19, 21, 23, 24]; activeMotif = [];
            const beats = [[0, 3, 6, 8, 11], [2, 4, 8, 10, 14], [0, 2, 6, 9, 12]][Math.floor(Math.random() * 3)];
            beats.forEach(step => activeMotif.push({ step, idx: range[Math.floor(Math.random() * range.length)] }));
        }

        // --- SCHEDULER & PLAYLIST LIFE CYCLES ---
        function triggerProceduralStep(step, time) {
            if (!activeProgression) return;
            let swing = (step % 2 !== 0) ? (((currentBeatStyle === "boombap") ? 0.035 : (currentBeatStyle === "garage" ? 0.05 : 0)) * (60.0 / bpm)) : 0;
            const pTime = time + swing;

            if (step === 0) {
                const chord = activeProgression.chords[activeChordIndex];
                synthChord(pTime, chord); synthBass(pTime, chord[0]);
            }
            const motif = activeMotif.find(m => m.step === step);
            if (motif && Math.random() < 0.8) synthMelody(pTime, motif.idx);

            if (currentBeatStyle === "boombap") {
                if (step === 0 || step === 8 || (step === 11 && Math.random() < 0.4)) synthKick(pTime);
                if (step === 4 || step === 12) synthSnare(pTime, false);
                if (step % 2 === 0) synthHiHat(pTime, step === 14 && Math.random() < 0.3);
            } else if (currentBeatStyle === "chillhop") {
                if (step === 0 || (step === 9 && Math.random() < 0.35)) synthKick(pTime);
                if (step === 4 || step === 12) synthSnare(pTime, true);
                if (step % 4 === 0) synthHiHat(pTime, false);
            } else if (currentBeatStyle === "garage") {
                if (step === 0 || step === 7 || step === 10) synthKick(pTime);
                if (step === 4 || step === 12) synthSnare(pTime, false);
                if (step % 3 === 0) synthHiHat(pTime, step === 9);
            }
        }

        function scheduler() {
            while (nextNoteTime < audioCtx.currentTime + scheduleAheadTime) {
                triggerProceduralStep(currentStep, nextNoteTime);
                const sPerBeat = 60.0 / bpm; nextNoteTime += 0.25 * sPerBeat;
                currentStep = (currentStep + 1) % 16;
                if (currentStep === 0) {
                    measureCount++;
                    activeChordIndex = (activeChordIndex + 1) % activeProgression.chords.length;
                    if (measureCount % 2 === 0) generateMelodicMotif();
                }
            }
            timerID = setTimeout(scheduler, lookahead);
        }

        function applyStyleTempo() {
            if (currentBeatStyle === "garage") bpm = Math.floor(Math.random() * 5) + 112;
            else if (currentBeatStyle === "boombap") bpm = Math.floor(Math.random() * 5) + 80;
            else if (currentBeatStyle === "chillhop") bpm = Math.floor(Math.random() * 5) + 68;
            else bpm = Math.floor(Math.random() * 5) + 55;
            bpmDisplay.innerText = `BPM: ${bpm}`;
            vinylDisc.style.setProperty('--spin-duration', `${(60 / bpm) * 4}s`);
        }

        function randomizeSettings() {
            const v = ["minor", "major", "dorian", "phrygian"];
            const b = ["boombap", "chillhop", "garage", "beatless"];
            const s = ["rhodes", "sines", "bells", "plucks"];
            
            currentModeKey = v[Math.floor(Math.random() * v.length)];
            currentBeatStyle = b[Math.floor(Math.random() * b.length)];
            currentSynthVoice = s[Math.floor(Math.random() * s.length)];

            selectVibe.value = currentModeKey;
            selectBeat.value = currentBeatStyle;
            selectSynth.value = currentSynthVoice;
        }

        function triggerSongChange() {
            if (isTransitioning) return; isTransitioning = true;
            deckStatus.innerText = "RETUNING";
            
            if (lofiFilter && masterGain) {
                lofiFilter.frequency.exponentialRampToValueAtTime(100, audioCtx.currentTime + 1.5);
                masterGain.gain.linearRampToValueAtTime(0, audioCtx.currentTime + 1.5);
            }
            vinylDisc.classList.remove('vinyl-spin');

            transitionTimeout = setTimeout(() => {
                randomizeSettings();
                trackTitleDisplay.innerText = makeTrackTitle();
                applyStyleTempo();

                if (audioCtx && delayNode) delayNode.delayTime.setValueAtTime((60.0 / bpm) * 0.75, audioCtx.currentTime);

                const tMode = modes[currentModeKey];
                scaleDisplay.innerText = `VIBE: ${tMode.name}`;
                activeProgression = tMode.progressions[Math.floor(Math.random() * tMode.progressions.length)];
                activeChordIndex = 0;
                generateMelodicMotif();

                songTimeElapsed = 0; progressBar.style.width = `0%`;

                if (lofiFilter && masterGain) {
                    lofiFilter.frequency.setValueAtTime(100, audioCtx.currentTime);
                    lofiFilter.frequency.exponentialRampToValueAtTime(parseFloat(sliderCutoff.value), audioCtx.currentTime + 1.0);
                    masterGain.gain.linearRampToValueAtTime(parseFloat(sliderVolume.value), audioCtx.currentTime + 1.0);
                }
                vinylDisc.classList.add('vinyl-spin');
                isTransitioning = false; deckStatus.innerText = "ON AIR";
            }, 1500);
        }

        // --- HARDWARE BITMAP VISUALIZER LOOP (ZERO REFLOW) ---
        function pokeBar(index, amount) {
            if (visBarsArray[index] !== undefined) visBarsArray[index] = amount;
        }

        function drawVisualizer() {
            animationFrameId = requestAnimationFrame(drawVisualizer);
            ctx.clearRect(0, 0, canvas.width, canvas.height);

            const barCount = 16;
            const gap = 3;
            const barWidth = (canvas.width - (gap * (barCount - 1))) / barCount;

            for (let i = 0; i < barCount; i++) {
                // Natural linear decay inside the JS thread space
                visBarsArray[i] *= 0.92;
                if (visBarsArray[i] < 0.05) visBarsArray[i] = 0.05;

                const bH = visBarsArray[i] * (canvas.height - 8);
                const x = i * (barWidth + gap);
                const y = canvas.height - bH - 4;

                // Alternate neon color profiles entirely in canvas pixel context
                ctx.fillStyle = i % 4 === 0 ? '#e55039' : (i % 2 === 0 ? '#38ada9' : '#f8c291');
                ctx.beginPath();
                ctx.roundRect(x, y, barWidth, bH, 3);
                ctx.fill();
            }
        }

        function startPlaylistTimer() {
            clearInterval(timerIntervalID);
            timerIntervalID = setInterval(() => {
                if (!isPlaying || isTransitioning) return;
                songTimeElapsed++;
                progressBar.style.width = `${(songTimeElapsed / autoSkipDuration) * 100}%`;

                const rem = Math.max(0, autoSkipDuration - songTimeElapsed);
                timeLeftDisplay.innerText = `${Math.floor(rem / 60).toString().padStart(2, '0')}:${(rem % 60).toString().padStart(2, '0')}`;
                if (songTimeElapsed >= autoSkipDuration) triggerSongChange();
            }, 1000);
        }

        // --- TRIGGER EVENT BINDINGS ---
        playBtn.addEventListener('click', () => {
            if (!audioCtx) initAudioPipeline();
            if (audioCtx.state === 'suspended') audioCtx.resume();

            isPlaying = !isPlaying;
            if (isPlaying) {
                playBtnText.innerText = "Pause Station"; deckStatus.innerText = "ON AIR";
                vinylDisc.classList.add('vinyl-spin');
                applyStyleTempo();
                
                const tMode = modes[currentModeKey];
                activeProgression = tMode.progressions[Math.floor(Math.random() * tMode.progressions.length)];
                trackTitleDisplay.innerText = makeTrackTitle();
                scaleDisplay.innerText = `VIBE: ${tMode.name}`;
                
                generateMelodicMotif();
                nextNoteTime = audioCtx.currentTime + 0.05;
                scheduler(); drawVisualizer(); startPlaylistTimer();
            } else {
                playBtnText.innerText = "Tune In"; deckStatus.innerText = "OFFLINE";
                vinylDisc.classList.remove('vinyl-spin');
                clearTimeout(timerID); clearInterval(timerIntervalID); cancelAnimationFrame(animationFrameId);
            }
        });

        skipBtn.addEventListener('click', () => {
            if (!isPlaying) { playBtn.click(); return; }
            triggerSongChange();
        });

        // Parameters Value Selectors
        selectVibe.addEventListener('change', (e) => {
            currentModeKey = e.target.value;
            const t = modes[currentModeKey]; scaleDisplay.innerText = `VIBE: ${t.name}`;
            activeProgression = t.progressions[Math.floor(Math.random() * t.progressions.length)]; activeChordIndex = 0;
            generateMelodicMotif();
        });
        selectBeat.addEventListener('change', (e) => { currentBeatStyle = e.target.value; applyStyleTempo(); });
        selectSynth.addEventListener('change', (e) => { currentSynthVoice = e.target.value; });
        selectInterval.addEventListener('change', (e) => { autoSkipDuration = parseInt(e.target.value); songTimeElapsed = 0; });

        // Sliders Core Connections
        sliderVolume.addEventListener('input', (e) => { masterGain.gain.setValueAtTime(parseFloat(e.target.value), audioCtx.currentTime); document.getElementById('vol-lbl').innerText = `${Math.round(e.target.value * 100)}%`; });
        sliderRain.addEventListener('input', (e) => { rainGain.gain.setValueAtTime(parseFloat(e.target.value), audioCtx.currentTime); document.getElementById('rain-lbl').innerText = `${Math.round((e.target.value / 0.15) * 100)}%`; });
        sliderCrackle.addEventListener('input', (e) => { crackleGain.gain.setValueAtTime(parseFloat(e.target.value), audioCtx.currentTime); document.getElementById('crackle-lbl').innerText = `${Math.round((e.target.value / 0.04) * 100)}%`; });
        sliderCutoff.addEventListener('input', (e) => { lofiFilter.frequency.setValueAtTime(parseFloat(e.target.value), audioCtx.currentTime); document.getElementById('cutoff-lbl').innerText = `${(e.target.value / 1000).toFixed(1)}k`; });
    </script>
