<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Generative Lo-Fi Player</title>
    <style>
        body {
            background-color: #2b2a33;
            color: #f8c291;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
            margin: 0;
            overflow: hidden;
        }
        #player-ui {
            background: #1e1d23;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0px 10px 30px rgba(0,0,0,0.5);
            text-align: center;
            width: 320px;
            border: 1px solid #3a3942;
        }
        h1 {
            font-size: 1.5rem;
            margin-top: 0;
            color: #e58e26;
        }
        #track-info {
            background: #000;
            color: #78e08f;
            padding: 10px;
            border-radius: 6px;
            font-family: 'Courier New', Courier, monospace;
            font-size: 0.9rem;
            margin-bottom: 20px;
            border: 1px solid #38ada9;
        }
        button {
            background: #e55039;
            color: white;
            border: none;
            padding: 12px 24px;
            font-size: 1.1rem;
            font-weight: bold;
            border-radius: 8px;
            cursor: pointer;
            transition: background 0.2s;
            width: 100%;
        }
        button:hover {
            background: #eb2f06;
        }
        .controls {
            margin-top: 20px;
            text-align: left;
        }
        .controls label {
            display: block;
            font-size: 0.85rem;
            margin-bottom: 5px;
            color: #b8b8b8;
        }
        input[type="range"] {
            width: 100%;
            accent-color: #e55039;
        }
    </style>
</head>
