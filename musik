<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cozy Procedural Lo-Fi Radio</title>
    <!-- Load Tailwind CSS for styling -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Share+Tech+Mono&display=swap" rel="stylesheet">
    
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #0b0a0f;
            background-image: radial-gradient(circle at center, #1e152a 0%, #08070b 100%);
        }
        
        .glow-orange {
            box-shadow: 0 0 15px rgba(245, 158, 11, 0.2);
            border-color: rgba(245, 158, 11, 0.4);
        }
        
        .glow-teal {
            box-shadow: 0 0 15px rgba(20, 184, 166, 0.2);
            border-color: rgba(20, 184, 166, 0.4);
        }
        
        .mono-font {
            font-family: 'Share Tech Mono', monospace;
        }

        /* Vinyl Spin animation with speed adjustments dynamically via JS */
        @keyframes spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
        .vinyl-spin {
            animation: spin var(--spin-duration, 4s) linear infinite;
            will-change: transform;
            transform: translateZ(0);
        }

        /* Ambient subtle pulse */
        @keyframes pulse-soft {
            0%, 100% { opacity: 0.6; transform: scale(1); }
            50% { opacity: 1; transform: scale(1.02); }
        }
        .pulse-ambient {
            animation: pulse-soft 3s infinite ease-in-out;
        }

        /* Strict visualizer boundaries to prevent layout shift */
        .visualizer-container {
            height: 48px; /* Strict fixed height */
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            background-color: rgba(9, 9, 11, 0.6);
            border: 1px solid rgba(63, 63, 70, 0.3);
            border-radius: 12px;
            padding: 8px 12px;
            box-sizing: border-box;
            overflow: hidden;
            width: 100%;
        }

        .visualizer-container .bar {
            flex: 1;
            margin: 0 2px;
            height: 32px; /* Strict height of content area (48 - 16 padding) */
            background-color: rgba(63, 63, 70, 0.5);
            border-radius: 4px;
            transform-origin: bottom;
            transform: scaleY(0.125); /* Default 4px / 32px = 0.125 */
            transition: transform 0.1s cubic-bezier(0.175, 0.885, 0.32, 1.15), background-color 0.1s ease;
            will-change: transform;
        }
    </style>
</head>
<body class="min-h-screen text-amber-100 flex flex-col justify-center items-center p-4 overflow-y-auto">

    <div class="w-full max-w-lg bg-zinc-950/80 backdrop-blur-xl border-2 border-zinc-800 rounded-3xl p-6 shadow-2xl relative overflow-hidden flex flex-col gap-6">
        
        <!-- Ambient Cassette Accent Header -->
        <div class="flex justify-between items-center border-b border-zinc-800/80 pb-4">
            <div class="flex items-center gap-2">
                <span class="w-3.5 h-3.5 rounded-full bg-red-500 animate-ping"></span>
                <span class="text-xs uppercase font-semibold text-zinc-500 tracking-wider mono-font">Procedural FM • Live Composition</span>
            </div>
            <div class="text-xs uppercase tracking-widest text-teal-400 font-bold mono-font" id="clock-display">
                DECK: COMPILING
            </div>
        </div>

        <div class="flex flex-col md:flex-row items-center gap-6 bg-zinc-900/40 p-4 rounded-2xl border border-zinc-800/50">
            <!-- Rotating Vinyl Deck -->
            <div class="relative w-28 h-28 shrink-0 flex-none">
                <div id="vinyl-disc" class="w-full h-full rounded-full bg-gradient-to-r from-zinc-800 via-black to-zinc-900 flex items-center justify-center shadow-lg relative border-4 border-zinc-950">
                    <!-- Vinyl Grooves -->
                    <div class="absolute inset-2 border border-zinc-800/40 rounded-full"></div>
                    <div class="absolute inset-4 border border-zinc-800/30 rounded-full"></div>
                    <div class="absolute inset-6 border border-zinc-800/20 rounded-full"></div>
                    <!-- Vinyl Center Sticker -->
                    <div class="w-10 h-10 rounded-full bg-amber-500/90 flex items-center justify-center border-2 border-zinc-950">
                        <div class="w-2.5 h-2.5 rounded-full bg-zinc-950"></div>
