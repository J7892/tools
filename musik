                    <div class="w-full h-2 bg-zinc-900 rounded-full overflow-hidden border border-zinc-800">
                        <div id="track-progress-bar" class="w-0 h-full bg-gradient-to-r from-amber-500 to-teal-400 transition-all duration-1000 ease-linear rounded-full"></div>
                    </div>
